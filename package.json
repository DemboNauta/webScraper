{
  "name": "web-scraper",
  "version": "1.0.0",
  "description": "Versatile web scraper for extracting business contacts (restaurants, etc.)",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "scrape": "node src/index.js",
    "server": "node src/server.js",
    "dev:server": "node --watch src/server.js",
    "dev:ui": "npm --prefix frontend run dev",
    "dev": "concurrently -n api,ui -c blue,green \"npm run dev:server\" \"npm run dev:ui\"",
    "install-browser": "npx puppeteer browsers install chrome"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "chalk": "^4.1.2",
    "cheerio": "^1.0.0",
    "commander": "^12.0.0",
    "cors": "^2.8.5",
    "csv-writer": "^1.6.0",
    "express": "^4.18.2",
    "p-limit": "^3.1.0",
    "puppeteer-core": "^21.0.0",
    "user-agents": "^1.1.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
